# Local: optional — mode defaults to non-production so DB_URL and DOMAIN can be auto-filled.
# Explicit development (optional):
# APP_ENV=development

# If unset in local dev, DB_URL is built from POSTGRES_PASSWORD (default password: admin).
POSTGRES_PASSWORD=admin

# Or set DB_URL yourself (skips auto-build):
# DB_URL=postgres://urlshort:YOUR_PASSWORD@localhost:5432/urlshort?sslmode=disable

# In local dev, short links use http://localhost:8080 when DOMAIN is unset.
# DOMAIN=http://127.0.0.1:8080

# --- Auth service (cmd/auth) — dedicated DB + Google OIDC --------------------
# Create DB once: createdb auth   (or: psql -U postgres -c 'CREATE DATABASE auth;')
# Apply schema: psql "$AUTH_DB_URL" -v ON_ERROR_STOP=1 -f server/cmd/auth/sql/schema/001_auth.up.sql
#
# GOOGLE_OAUTH_CLIENT_ID=
# GOOGLE_OAUTH_CLIENT_SECRET=
#
# Public URL of this auth API (used for default redirect URI).
# AUTH_PUBLIC_BASE_URL=http://localhost:8082
# Production example:
# AUTH_PUBLIC_BASE_URL=https://utilitools.tech
#
# Optional override; default is {AUTH_PUBLIC_BASE_URL}/api/auth/google/callback
# AUTH_GOOGLE_REDIRECT_URL=http://localhost:8082/api/auth/google/callback
# Production example:
# AUTH_GOOGLE_REDIRECT_URL=https://utilitools.tech/api/auth/google/callback
#
# Optional; default builds postgres://...@localhost:5432/auth
# AUTH_DB_URL=postgres://postgres:admin@localhost:5432/auth?sslmode=disable
#
# Listen address for the auth server
# AUTH_HTTP_ADDR=:8082
#
# Where to send the browser after successful login (your frontend)
# AUTH_POST_LOGIN_REDIRECT=http://localhost:3000/
# Production example:
# AUTH_POST_LOGIN_REDIRECT=https://utilitools.tech/
#
# Session cookie lifetime in days (default 30)
# AUTH_SESSION_DAYS=30
