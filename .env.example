# Docker Compose — copy to `.env` at repo root (never commit `.env`).

POSTGRES_PASSWORD=change_me_to_a_strong_password

# Browser-facing origin for short links (what users type in the address bar).
#
# Local Docker: omit COMPOSE_DOMAIN and DOMAIN → Compose defaults to http://localhost.
# If your `.env` still has DOMAIN pointing at a VPS, set this so local wins:
#   COMPOSE_DOMAIN=http://localhost
#
# VPS / production:
#   COMPOSE_DOMAIN=http://YOUR_PUBLIC_IP
#   COMPOSE_DOMAIN=https://utilitools.tech
#
# COMPOSE_DOMAIN=

# Domain(s) for TLS certificates (space-separated).
# CERTBOT_DOMAINS=utilitools.tech www.utilitools.tech

# Legacy fallback only if COMPOSE_DOMAIN is unset (prefer COMPOSE_DOMAIN above).
# DOMAIN=

# Email used for Let's Encrypt expiry/security notices.
# LETSENCRYPT_EMAIL=you@example.com
